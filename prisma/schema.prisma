datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum EventType {
  SIGNUP
  CONTRACT_CREATED
  PAYMENT_COMPLETED
  WITHDRAW_REQUESTED
}

enum InstallmentStatus {
  OPEN
  OVERDUE
  PAID
}

enum PurchaseStatus {
  INITIATED
  FUNDS_ESCROWED
  LEGAL_VERIFIED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  RESOLVED
}

model BusinessEvent {
  id        String    @id @default(cuid())
  type      EventType
  userId    String?
  entityId  String?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([type, createdAt])
}

model DailyKPI {
  id               String   @id @default(cuid())
  date             DateTime @unique
  signups          Int      @default(0)
  contracts        Int      @default(0)
  payments         Int      @default(0)
  withdrawalCount  Int      @default(0)
  withdrawalVolume Float    @default(0)
  grossVolume      Float    @default(0)
  netCashFlow      Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  avatarUrl String?
  preferredLanguage String @default("fr")
  notifyEmail Boolean @default(true)
  notifySms Boolean @default(false)
  notifyPush Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  dashboardCompact Boolean @default(false)
  companyName String?
  companyLogoUrl String?
  lastLoginAt DateTime?
  role      String   @default("TENANT") // ADMIN, MANAGER, TENANT
  isSuspended Boolean @default(false)
  suspendedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProperties Property[] @relation("PropertyManager")
  contracts         Contract[]
  wishlistItems     WishlistItem[]
  loginHistory      LoginHistory[]
  updatedSystemConfigs SystemConfig[] @relation("SystemConfigUpdatedBy")
  buyerTransactions  PurchaseTransaction[] @relation("PurchaseBuyer")
  sellerTransactions PurchaseTransaction[] @relation("PurchaseSeller")
}

model SystemLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
}

model FinancialAuditLog {
  id            String   @id @default(cuid())
  type          String // PAYMENT, WITHDRAWAL
  entityId      String
  fromStatus    String?
  toStatus      String
  actorId       String?
  correlationId String?
  metadata      String?
  createdAt     DateTime @default(now())

  @@index([type, entityId, createdAt])
  @@index([correlationId])
  @@index([actorId, createdAt])
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String?
  city        String?
  address     String
  price       Float
  offerType   String   @default("RENT") // RENT, SALE
  propertyType String  @default("APARTMENT") // APARTMENT, HOUSE, STUDIO, COMMERCIAL, LAND
  status      String   @default("AVAILABLE") // AVAILABLE, PENDING_TRANSACTION, SOLD, RENTED, MAINTENANCE
  isPublished Boolean  @default(false)
  isPremium   Boolean  @default(false)
  viewsCount  Int      @default(0)
  impressionsCount Int @default(0)
  inquiriesCount Int   @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  managerId   String?
  manager     User?    @relation("PropertyManager", fields: [managerId], references: [id])

  contracts   Contract[]
  images      PropertyImage[]
  inquiries   MarketplaceInquiry[]
  wishlistedBy WishlistItem[]
  purchaseTransactions PurchaseTransaction[]

  @@index([isPublished])
  @@index([isPublished, status])
  @@index([isPublished, status, offerType])
  @@index([isPremium])
  @@index([viewsCount])
  @@index([inquiriesCount])
  @@index([status])
  @@index([offerType])
  @@index([propertyType])
  @@index([city])
  @@index([address])
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Contract {
  id            String   @id @default(cuid())
  startDate     DateTime
  endDate       DateTime
  rentAmount    Float
  depositAmount Float
  contractType  String   @default("RENTAL") // RENTAL, SALE
  workflowState String   @default("DRAFT") // DRAFT, SUBMITTED, SIGNED_BOTH, PAYMENT_INITIATED, ACTIVE
  documentSource String? // UPLOAD, DRAFT
  status        String   @default("ACTIVE") // ACTIVE, TERMINATED, EXPIRED
  fileUrl       String?
  contractText  String?
  receiptFileUrl String?
  receiptText   String?
  submittedAt   DateTime?
  ownerSignedAt DateTime?
  tenantSignedAt DateTime?
  paymentInitiatedAt DateTime?
  activatedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  tenantId String
  tenant   User   @relation(fields: [tenantId], references: [id])

  payments Payment[]
  installments ContractInstallment[]

  @@index([workflowState])
  @@index([contractType])
}

model Payment {
  id            String   @id @default(cuid())
  amount        Float
  status        String   @default("PENDING") // PENDING, COMPLETED, FAILED
  type          String   @default("RENT") // RENT, DEPOSIT, OTHER
  method        String // MOMO_MTN, MOOV, CASH
  transactionId String?  @unique
  idempotencyKey String? @unique
  tenantId      String?
  propertyId    String?
  initiatedById String?
  initiatedByRole String?
  receiptNumber String?  @unique
  receiptIssuedAt DateTime?
  ownerNotifiedAt DateTime?
  installmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  installment ContractInstallment? @relation(fields: [installmentId], references: [id])

  @@index([installmentId])
}

model ContractInstallment {
  id            String            @id @default(cuid())
  contractId    String
  sequence      Int
  dueDate       DateTime
  baseAmount    Decimal
  penaltyAmount Decimal           @default(0)
  totalDue      Decimal
  status        InstallmentStatus @default(OPEN)
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  contract      Contract          @relation(fields: [contractId], references: [id])
  payments      Payment[]

  @@unique([contractId, sequence])
  @@index([contractId, status])
  @@index([dueDate, status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("INFO")
  title     String
  message   String
  paymentId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([paymentId])
}

model MarketplaceInquiry {
  id                 String   @id @default(cuid())
  propertyId         String
  requesterUserId    String?
  requesterIp        String?
  requesterName      String
  requesterEmail     String
  requesterPhone     String?
  message            String?
  preferredVisitDate DateTime?
  status             String   @default("NEW") // NEW, CONTACTED, CLOSED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
  @@index([requesterEmail])
  @@index([requesterIp, createdAt])
}

model WishlistItem {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId, createdAt])
  @@index([propertyId, createdAt])
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  success    Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy   User?    @relation("SystemConfigUpdatedBy", fields: [updatedById], references: [id])

  @@index([updatedAt])
}

model PurchaseTransaction {
  id           String         @id @default(cuid())
  propertyId   String
  buyerId      String
  sellerId     String?
  status       PurchaseStatus @default(INITIATED)
  escrowAmount Decimal
  totalAmount  Decimal
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  property     Property       @relation(fields: [propertyId], references: [id])
  buyer        User           @relation("PurchaseBuyer", fields: [buyerId], references: [id])
  seller       User?          @relation("PurchaseSeller", fields: [sellerId], references: [id])
  legalVerification LegalVerification?
  disputes     Dispute[]

  @@index([propertyId, status])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
}

model LegalVerification {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  documentUrl     String?
  buyerConfirmedAt DateTime?
  sellerUploadedAt DateTime?
  adminVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     PurchaseTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Dispute {
  id            String        @id @default(cuid())
  transactionId String
  reason        String
  status        DisputeStatus @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transaction   PurchaseTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, status])
}
